{
  "name": "satellite-data-toolkit",
  "version": "2.1.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "version:check": "node scripts/check-version-consistency.mjs",
    "security:tauri-surface": "node scripts/check-tauri-surface.mjs",
    "test": "vitest --run",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "visual:smoke": "node scripts/visual-smoke.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "verify": "node scripts/verify.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "lucide-react": "1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "playwright": "^1.59.1",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  }
}
